        <mxCell id="sync_a4_no" edge="1" parent="1" source="sync_exists" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;" target="sync_create" value="No (new)">
          <mxGeometry relative="1" as="geometry" />
