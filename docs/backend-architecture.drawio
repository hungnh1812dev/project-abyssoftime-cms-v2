          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sync_create" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;CREATE new content-type&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;1. Insert ContentType record into DB&lt;br&gt;2. Create document table (see below)&lt;br&gt;3. Create component tables (if any)&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="280" x="235" y="530" as="geometry" />
        </mxCell>
        <mxCell id="sync_update" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;UPDATE existing content-type&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;1. EnsureCollection (add missing columns)&lt;br&gt;2. Ensure component tables&lt;br&gt;3. Update ContentType record if changed&lt;/font&gt;" vertex="1">
