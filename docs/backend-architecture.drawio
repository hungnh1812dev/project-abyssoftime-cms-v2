        <mxCell id="step2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" value="&lt;b&gt;1. config.Load()&lt;/b&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;Load environment variables&lt;br&gt;&lt;font color=&quot;#666&quot; size=&quot;2&quot;&gt;PORT, DB_*, JWT_SECRET, CORS_*, STORAGE_*&lt;br&gt;Parse per-entity DB overrides (DB_ENTITY_*)&lt;br&gt;Return strongly-typed Config struct&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="80" width="360" x="520" y="180" as="geometry" />
        </mxCell>
        <mxCell id="arrow2" edge="1" parent="1" source="step2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" value="&lt;b&gt;2. pkgjwt.SetSecret()&lt;/b&gt;&lt;br&gt;Initialize global HMAC signing key (HS256)" vertex="1">
          <mxGeometry height="50" width="280" x="560" y="290" as="geometry" />
        </mxCell>
        <mxCell id="arrow3" edge="1" parent="1" source="step3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step4_group">
