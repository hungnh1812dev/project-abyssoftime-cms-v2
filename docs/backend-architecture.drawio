        </mxCell>
        <mxCell id="pg_nested_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=10;" value="&lt;b&gt;Nested Component Tables&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;When a component contains another component,&lt;br&gt;tables are created with path prefix:&lt;br&gt;&lt;br&gt;components_cv_page_&lt;b&gt;skills&lt;/b&gt;&lt;br&gt;components_cv_page_&lt;b&gt;experiences&lt;/b&gt;&lt;br&gt;components_cv_page_&lt;b&gt;experiences_roles&lt;/b&gt; ← nested&lt;/font&gt;" vertex="1">
          <mxGeometry height="140" width="280" x="1085" y="690" as="geometry" />
        </mxCell>
        <mxCell id="mongo_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#2E7D32;fontStyle=1;" value="&lt;b&gt;MongoDB: Dynamic Collection Creation&lt;/b&gt;&lt;br&gt;mongodb/document_repository.go" vertex="1">
          <mxGeometry height="30" width="500" x="75" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="mongo_col" parent="1" style="swimlane;startSize=35;fillColor=#E8F5E9;strokeColor=#2E7D32;rounded=1;fontSize=11;fontColor=#2E7D32;" value="Collection: documents_&lt;slug&gt;&#xa;e.g. documents_cv-page" vertex="1">
          <mxGeometry height="250" width="500" x="75" y="1070" as="geometry" />
        </mxCell>
        <mxCell id="mongo_doc" parent="mongo_col" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2E7D32;fontSize=10;align=left;verticalAlign=top;" value="&lt;pre style=&quot;text-align:left;font-size:10px;margin:0;padding:5px;&quot;&gt;{&lt;br&gt;  &quot;_id&quot;: ObjectId(...),&lt;br&gt;  &quot;documentId&quot;: &quot;uuid-v4&quot;,&lt;br&gt;  &quot;version&quot;: &quot;draft&quot;,          // or &quot;published&quot;&lt;br&gt;  &quot;locale&quot;: &quot;en&quot;,&lt;br&gt;  &quot;data&quot;: {                    // all field values as nested map&lt;br&gt;    &quot;position&quot;: &quot;Senior Dev&quot;,&lt;br&gt;    &quot;isMain&quot;: true,&lt;br&gt;    &quot;company&quot;: &quot;ACME&quot;,&lt;br&gt;    &quot;skills&quot;: [{&quot;level&quot;:&quot;expert&quot;, &quot;skill&quot;:&quot;Go&quot;}, ...]&lt;br&gt;  },&lt;br&gt;  &quot;createdAt&quot;: ISODate(...),&lt;br&gt;  &quot;createdBy&quot;: &quot;user-uuid&quot;&lt;br&gt;}&lt;/pre&gt;" vertex="1">
          <mxGeometry height="200" width="480" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="mongo_idx" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=10;" value="&lt;b&gt;Unique Index&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;{documentId: 1, version: 1, locale: 1}&lt;br&gt;Ensures one draft + one published&lt;br&gt;per document per locale&lt;/font&gt;" vertex="1">
          <mxGeometry height="90" width="280" x="635" y="1090" as="geometry" />
        </mxCell>
        <mxCell id="mongo_diff" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=11;align=left;spacingLeft=10;" value="&lt;b&gt;Key Difference: MongoDB vs PostgreSQL&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;&lt;b&gt;MongoDB:&lt;/b&gt; All fields stored as nested &lt;b&gt;data&lt;/b&gt; map, schema-less.&lt;br&gt;Components embedded in document, no separate collections.&lt;br&gt;&lt;br&gt;&lt;b&gt;PostgreSQL:&lt;/b&gt; Each field becomes a typed &lt;b&gt;column&lt;/b&gt;.&lt;br&gt;Components get separate tables linked by document_id.&lt;br&gt;Layout fields are flattened into parent table columns.&lt;/font&gt;" vertex="1">
          <mxGeometry height="120" width="400" x="635" y="1200" as="geometry" />
        </mxCell>
        <mxCell id="flattenNote" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=10;" value="&lt;b&gt;flattenLayoutFields()&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;Layout fields are a UI-only concept.&lt;br&gt;At DB level, layout children are&lt;br&gt;promoted to top-level columns:&lt;br&gt;&lt;br&gt;{type: &quot;layout&quot;, fields: [&lt;br&gt;  {name: &quot;phone&quot;}, {name: &quot;email&quot;}&lt;br&gt;]}  →  phone TEXT, email TEXT&lt;/font&gt;" vertex="1">
          <mxGeometry height="150" width="280" x="1085" y="870" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
