          <mxGeometry height="90" width="120" x="160" y="35" as="geometry" />
        </mxCell>
        <mxCell id="err_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=15;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;align=center;" value="&lt;b&gt;Error → HTTP Status Mapping&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;ErrConflict → 409&lt;/font&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;ErrUnauthorized → 401&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;ErrForbidden → 403&lt;br&gt;ErrNotFound → 404&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;ErrBadRequest → 400&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;ErrValidation → 422&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;Unknown → 500&lt;/font&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="260" x="60" y="470" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="auth-flow" name="3. Authentication Flow">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title3" value="&lt;b&gt;Authentication Flows&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="550" y="20" width="300" height="40" as="geometry" />
        </mxCell>
        <!-- ===== REGISTER FLOW ===== -->
        <mxCell id="reg_title" value="&lt;b&gt;REGISTER&lt;/b&gt; (first user only → super_admin) — POST /auth/register" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="reg1" value="Client&lt;br&gt;POST /auth/register&lt;br&gt;&lt;font size=&quot;1&quot;&gt;{email, password,&lt;br&gt;displayName}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reg2" value="HasSuperAdmin?&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(must be false)&lt;/font&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="310" y="100" width="150" height="90" as="geometry" />
        </mxCell>
        <mxCell id="reg3" value="bcrypt hash&lt;br&gt;password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="530" y="115" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="reg4" value="Create User&lt;br&gt;with &lt;b&gt;super_admin&lt;/b&gt;&lt;br&gt;role + return tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="730" y="110" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="reg_err" value="&lt;font color=&quot;#b85450&quot;&gt;&lt;b&gt;403&lt;/b&gt; Forbidden&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="340" y="210" width="90" height="40" as="geometry" />
        </mxCell>
        <mxCell id="reg_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="reg1" target="reg2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="reg_a2" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="reg2" target="reg3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="reg_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="reg3" target="reg4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="reg_a4" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="reg2" target="reg_err">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ===== LOGIN FLOW ===== -->
        <mxCell id="login_title" value="&lt;b&gt;LOGIN&lt;/b&gt; — POST /auth/login" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="280" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="log1" value="Client&lt;br&gt;POST /auth/login&lt;br&gt;&lt;font size=&quot;1&quot;&gt;{email, password,&lt;br&gt;rememberMe?}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="150" height="70" as="geometry" />
        </mxCell>
        <mxCell id="log2" value="Find user&lt;br&gt;by email" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="330" width="110" height="50" as="geometry" />
        </mxCell>
        <mxCell id="log3" value="bcrypt.Compare&lt;br&gt;password" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="330" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="log4" value="Resolve role slug&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(role table, fallback&lt;br&gt;to user.Role)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="640" y="325" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="log5" value="Generate tokens&lt;br&gt;&lt;font size=&quot;1&quot;&gt;&lt;b&gt;Access:&lt;/b&gt; 15 min (HS256)&lt;br&gt;{userID, role}&lt;br&gt;&lt;b&gt;Refresh:&lt;/b&gt; 7d (HS256)&lt;br&gt;{userID}&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="830" y="310" width="160" height="90" as="geometry" />
        </mxCell>
        <mxCell id="log6" value="Set HttpOnly&lt;br&gt;refresh cookie&lt;br&gt;&lt;font size=&quot;1&quot;&gt;+ return access&lt;br&gt;token in body&lt;br&gt;&lt;br&gt;Cookie: Secure,&lt;br&gt;SameSite(configurable)&lt;br&gt;MaxAge: 7d (14d if&lt;br&gt;rememberMe)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1050" y="300" width="160" height="120" as="geometry" />
        </mxCell>
        <mxCell id="log_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="log1" target="log2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="log_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="log2" target="log3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="log_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="log3" target="log4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="log_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="log4" target="log5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="log_a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="log5" target="log6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ===== REFRESH FLOW ===== -->
        <mxCell id="ref_title" value="&lt;b&gt;REFRESH TOKEN&lt;/b&gt; — POST /auth/refresh" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="460" width="400" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ref1" value="Client&lt;br&gt;POST /auth/refresh&lt;br&gt;&lt;font size=&quot;1&quot;&gt;(body or cookie)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="500" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ref2" value="Extract refresh&lt;br&gt;token&lt;br&gt;&lt;font size=&quot;1&quot;&gt;body first,&lt;br&gt;fallback cookie&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="495" width="130" height="70" as="geometry" />
        </mxCell>
        <mxCell id="ref3" value="Validate token&lt;br&gt;+ load user&lt;br&gt;+ resolve role" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="500" y="500" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ref4" value="Issue new&lt;br&gt;access + refresh&lt;br&gt;tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="500" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ref_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="ref1" target="ref2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ref_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="ref2" target="ref3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ref_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="ref3" target="ref4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- ===== PROTECTED REQUEST FLOW ===== -->
        <mxCell id="prot_title" value="&lt;b&gt;PROTECTED REQUEST&lt;/b&gt; — Any authenticated endpoint" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="600" width="500" height="30" as="geometry" />
        </mxCell>
        <mxCell id="prot1" value="Client&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Authorization:&lt;br&gt;Bearer &amp;lt;token&amp;gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prot2" value="Extract &amp;amp;&lt;br&gt;validate JWT&lt;br&gt;&lt;font size=&quot;1&quot;&gt;HS256&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="640" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prot3" value="Inject userID&lt;br&gt;+ role into&lt;br&gt;context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="470" y="640" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prot4" value="Check permission&lt;br&gt;against role cache" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="660" y="640" width="130" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prot5" value="&lt;b&gt;Handler&lt;/b&gt;&lt;br&gt;processes&lt;br&gt;request" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="860" y="640" width="110" height="60" as="geometry" />
        </mxCell>
        <mxCell id="prot_a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="prot1" target="prot2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="prot_a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="prot2" target="prot3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="prot_a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="prot3" target="prot4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="prot_a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;endArrow=block;endFill=1;" edge="1" parent="1" source="prot4" target="prot5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Permission Strings Box -->
        <mxCell id="perm_box" value="&lt;b&gt;Permission Strings&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;content:read | content:create | content:update | content:delete | content:publish | content:unpublish&lt;br&gt;media:read | media:upload | media:delete&lt;br&gt;users:manage | roles:manage | access_tokens:manage | content_types:read | locales:manage&lt;/font&gt;" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="740" width="600" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="clean-arch" name="4. Clean Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <!-- Title -->
        <mxCell id="title4" value="&lt;b&gt;Clean Architecture Layers&lt;/b&gt;&lt;br&gt;Dependency direction: outer → inner" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="420" y="20" width="400" height="50" as="geometry" />
        </mxCell>
        <!-- Outermost: Delivery Layer -->
        <mxCell id="delivery_outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="120" y="90" width="1000" height="780" as="geometry" />
        </mxCell>
        <mxCell id="delivery_label" value="&lt;b&gt;DELIVERY LAYER&lt;/b&gt; (outermost)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontColor=#1565C0;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="140" y="100" width="300" height="30" as="geometry" />
        </mxCell>
        <!-- Delivery: REST -->
        <mxCell id="del_rest" value="&lt;b&gt;REST / Gin&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;internal/delivery/http/&lt;br&gt;handler/*.go&lt;br&gt;router.go&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="160" y="140" width="200" height="80" as="geometry" />
        </mxCell>
        <!-- Delivery: GraphQL -->
        <mxCell id="del_gql" value="&lt;b&gt;GraphQL&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;graphql/dynamic/&lt;br&gt;resolver_factory.go&lt;br&gt;Dynamic schema from&lt;br&gt;content-type JSON&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="140" width="200" height="80" as="geometry" />
        </mxCell>
        <!-- Delivery: gRPC -->
        <mxCell id="del_grpc" value="&lt;b&gt;gRPC&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;internal/delivery/grpc/&lt;br&gt;Proto-based services&lt;br&gt;Auth, ContentType,&lt;br&gt;Document, Media&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1565C0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="680" y="140" width="200" height="80" as="geometry" />
        </mxCell>
        <!-- Middleware bar -->
        <mxCell id="mw_bar" value="&lt;b&gt;Middleware:&lt;/b&gt;  CORS → JWT Auth → Role/Permission Check (in-memory cache)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=12;fontColor=#E65100;" vertex="1" parent="1">
          <mxGeometry x="160" y="240" width="720" height="35" as="geometry" />
        </mxCell>
        <!-- UseCase Layer -->
        <mxCell id="uc_outer" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F9A825;strokeWidth=2;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="200" y="310" width="840" height="200" as="geometry" />
        </mxCell>
        <mxCell id="uc_label" value="&lt;b&gt;USECASE LAYER&lt;/b&gt; (business logic)" style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;fontSize=14;fontColor=#F9A825;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="315" width="300" height="30" as="geometry" />
        </mxCell>
        <mxCell id="uc_auth" value="&lt;b&gt;Auth&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Login, Register&lt;br&gt;Token mgmt&lt;br&gt;bcrypt&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_doc" value="&lt;b&gt;Document&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;CRUD&lt;br&gt;Publish/Unpublish&lt;br&gt;Versioning&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_ct" value="&lt;b&gt;ContentType&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Sync JSON→DB&lt;br&gt;List, Update&lt;br&gt;ListFields&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_media" value="&lt;b&gt;Media&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Upload, Delete&lt;br&gt;List, Thumbnail&lt;br&gt;generation&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="580" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_role" value="&lt;b&gt;Role&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;CRUD&lt;br&gt;Permissions&lt;br&gt;Hierarchy&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_more" value="&lt;b&gt;+ More&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Invite, Locale&lt;br&gt;AccessToken&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="350" width="100" height="70" as="geometry" />
        </mxCell>
        <mxCell id="uc_note" value="Depends on repository &lt;b&gt;interfaces&lt;/b&gt; (contracts), not implementations" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=11;fontColor=#888;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="440" width="500" height="25" as="geometry" />
        </mxCell>
        <!-- Arrows: Delivery → UseCase -->
        <mxCell id="a_del_uc1" value="calls" style="endArrow=block;endFill=1;html=1;rounded=1;strokeWidth=2;strokeColor=#666;exitX=0.5;exitY=1;entryX=0.2;entryY=0;dashed=1;" edge="1" parent="1" source="del_rest" target="uc_outer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a_del_uc2" value="calls" style="endArrow=block;endFill=1;html=1;rounded=1;strokeWidth=2;strokeColor=#666;exitX=0.5;exitY=1;entryX=0.5;entryY=0;dashed=1;" edge="1" parent="1" source="del_gql" target="uc_outer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
