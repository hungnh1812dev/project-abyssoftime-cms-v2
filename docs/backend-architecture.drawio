        <mxCell id="ct_schema_code" parent="ct_json_struct" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;align=left;verticalAlign=top;" value="&lt;pre style=&quot;text-align:left;font-size:11px;margin:0;padding:5px;&quot;&gt;{&lt;br&gt;  &quot;slug&quot;: &quot;cv-page&quot;,        // unique identifier&lt;br&gt;  &quot;name&quot;: &quot;CV Page&quot;,        // display name&lt;br&gt;  &quot;kind&quot;: &quot;collection&quot;,     // &quot;single&quot; or &quot;collection&quot;&lt;br&gt;  &quot;fields&quot;: [               // field definitions array&lt;br&gt;    { &quot;name&quot;: &quot;title&quot;, &quot;type&quot;: &quot;text&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;body&quot;, &quot;type&quot;: &quot;richtext&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;count&quot;, &quot;type&quot;: &quot;number&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;active&quot;, &quot;type&quot;: &quot;boolean&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;avatar&quot;, &quot;type&quot;: &quot;media&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;metadata&quot;, &quot;type&quot;: &quot;json&quot; },&lt;br&gt;    {                         // layout: UI grouping&lt;br&gt;      &quot;type&quot;: &quot;layout&quot;,&lt;br&gt;      &quot;fields&quot;: [&lt;br&gt;        { &quot;name&quot;: &quot;phone&quot;, &quot;type&quot;: &quot;text&quot; },&lt;br&gt;        { &quot;name&quot;: &quot;email&quot;, &quot;type&quot;: &quot;text&quot; }&lt;br&gt;      ]&lt;br&gt;    },&lt;br&gt;    {                         // component: repeatable&lt;br&gt;      &quot;name&quot;: &quot;skills&quot;,&lt;br&gt;      &quot;type&quot;: &quot;component&quot;,&lt;br&gt;      &quot;repeatable&quot;: true,&lt;br&gt;      &quot;fields&quot;: [...]         // nested fields&lt;br&gt;    }&lt;br&gt;  ]&lt;br&gt;}&lt;/pre&gt;" vertex="1">
          <mxGeometry height="380" width="490" x="15" y="40" as="geometry" />
        </mxCell>
        <mxCell id="ct_field_types" parent="1" style="swimlane;startSize=25;fillColor=#FFF3E0;strokeColor=#E65100;rounded=1;fontSize=12;fontColor=#E65100;" value="Field Types" vertex="1">
