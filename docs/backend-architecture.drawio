        </mxCell>
        <mxCell id="step9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" value="&lt;b&gt;8. Setup HTTP Router (Gin) + gRPC Server&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;Register middleware (CORS, Auth, Permission)&lt;br&gt;Mount all REST routes + GraphQL endpoint&lt;br&gt;Register gRPC services with interceptors&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="400" x="500" y="930" as="geometry" />
        </mxCell>
