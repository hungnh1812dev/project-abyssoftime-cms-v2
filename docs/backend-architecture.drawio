        </mxCell>
        <mxCell id="step4_group" parent="1" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;rounded=1;fontSize=12;" value="3. Database Connections (dual-database support)" vertex="1">
          <mxGeometry height="120" width="560" x="420" y="370" as="geometry">
            <mxRectangle height="30" width="310" x="420" y="370" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="db_mongo" parent="step4_group" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;MongoDB&lt;/b&gt; (default)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Build URI from DB_*&lt;br&gt;TLS 1.2+ / 30s timeout&lt;br&gt;EnsureIndexes()&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="230" x="30" y="40" as="geometry" />
        </mxCell>
        <mxCell id="db_pg" parent="step4_group" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="&lt;b&gt;PostgreSQL&lt;/b&gt; (GORM ORM)&lt;br&gt;&lt;font size=&quot;1&quot;&gt;Build DSN / Auto-migrate&lt;br&gt;Create tables / Ping verify&lt;br&gt;User, ContentType, MediaAsset, Role...&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="230" x="300" y="40" as="geometry" />
        </mxCell>
        <mxCell id="arrow4" edge="1" parent="1" source="step4_group" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;" target="step5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;arcSize=15;" value="&lt;b&gt;4. Create Repository Instances&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;UserRepo | ContentTypeRepo | DocumentRepo | MediaAssetRepo&lt;br&gt;RoleRepo | InviteRepo | AccessTokenRepo | LocaleRepo&lt;br&gt;StorageAdapter (Cloudinary or S3)&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="440" x="480" y="520" as="geometry" />
        </mxCell>
        <mxCell id="arrow5" edge="1" parent="1" source="step5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;arcSize=15;" value="&lt;b&gt;5. Initialize UseCase Layer&lt;/b&gt; (business logic)&lt;br&gt;&lt;font size=&quot;2&quot;&gt;AuthUseCase | ContentTypeUseCase | DocumentUseCase&lt;br&gt;MediaUseCase | RoleUseCase | InviteUseCase&lt;br&gt;AccessTokenUseCase | LocaleUseCase&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="440" x="480" y="620" as="geometry" />
        </mxCell>
        <mxCell id="arrow6" edge="1" parent="1" source="step6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;arcSize=15;" value="&lt;b&gt;6. Seed Defaults&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;Roles: super_admin(4), admin(3), editor(2), guest(1)&lt;br&gt;Locales from SUPPORTED_LOCALES (en, vi)&lt;br&gt;Sync content-types/*.json → DB&lt;br&gt;Preload role-permission cache (in-memory)&lt;/font&gt;" vertex="1">
          <mxGeometry height="80" width="400" x="500" y="720" as="geometry" />
        </mxCell>
        <mxCell id="arrow7" edge="1" parent="1" source="step7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="step8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;arcSize=15;" value="&lt;b&gt;7. Build Dynamic GraphQL Schema&lt;/b&gt;&lt;br&gt;&lt;font size=&quot;2&quot;&gt;ResolverFactory reads content-type definitions&lt;br&gt;Generate Query/Mutation types, recursive field types&lt;br&gt;Register custom JSON scalar&lt;/font&gt;" vertex="1">
          <mxGeometry height="70" width="400" x="500" y="830" as="geometry" />
        </mxCell>
        <mxCell id="arrow8" edge="1" parent="1" source="step8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" target="step9">
