        <mxCell id="sync_exists" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="Content-type&lt;br&gt;exists in DB?" vertex="1">
