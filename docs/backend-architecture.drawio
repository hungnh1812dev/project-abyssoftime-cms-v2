          <mxGeometry height="25" width="410" x="10" y="95" as="geometry" />
        </mxCell>
        <mxCell id="ft_boolean" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;boolean&lt;/b&gt; → BOOLEAN column (PG) / boolean (Mongo)" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="125" as="geometry" />
        </mxCell>
        <mxCell id="ft_media" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;media&lt;/b&gt; → TEXT column (PG, stores documentId) / string (Mongo)" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="155" as="geometry" />
        </mxCell>
        <mxCell id="ft_json" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;json&lt;/b&gt; → TEXT column (PG, serialized) / object (Mongo)" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="185" as="geometry" />
        </mxCell>
        <mxCell id="ft_date" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;date&lt;/b&gt; → TEXT column (PG) / string (Mongo)" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="215" as="geometry" />
        </mxCell>
        <mxCell id="ft_layout" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;layout&lt;/b&gt; → UI-only grouping, children flattened into parent table" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="250" as="geometry" />
        </mxCell>
        <mxCell id="ft_component" parent="ct_field_types" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;component&lt;/b&gt; → separate table: components_&lt;slug&gt;_&lt;name&gt; (PG) / embedded (Mongo)" vertex="1">
          <mxGeometry height="25" width="410" x="10" y="280" as="geometry" />
        </mxCell>
        <mxCell id="ct_kind_box" parent="1" style="swimlane;startSize=25;fillColor=#E8F5E9;strokeColor=#2E7D32;rounded=1;fontSize=12;fontColor=#2E7D32;" value="Content Kind" vertex="1">
          <mxGeometry height="110" width="520" x="50" y="540" as="geometry" />
        </mxCell>
        <mxCell id="kind_single" parent="ct_kind_box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;single&lt;/b&gt; — One document per content-type (e.g. homepage, settings, contact page).&lt;br&gt;Only GET/PUT endpoints, no list/create/delete." vertex="1">
          <mxGeometry height="35" width="500" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="kind_collection" parent="ct_kind_box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=8;" value="&lt;b&gt;collection&lt;/b&gt; — Multiple documents per content-type (e.g. blog posts, products).&lt;br&gt;Full CRUD + pagination + publish/unpublish + duplicate." vertex="1">
          <mxGeometry height="35" width="500" x="10" y="70" as="geometry" />
        </mxCell>
        <mxCell id="ct_validation" parent="1" style="swimlane;startSize=25;fillColor=#FCE4EC;strokeColor=#C62828;rounded=1;fontSize=12;fontColor=#C62828;" value="Validation Rules (schema_loader.go)" vertex="1">
          <mxGeometry height="110" width="430" x="620" y="540" as="geometry" />
        </mxCell>
        <mxCell id="val1" parent="ct_validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" value="slug and name are required" vertex="1">
          <mxGeometry height="22" width="410" x="10" y="28" as="geometry" />
        </mxCell>
        <mxCell id="val2" parent="ct_validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" value="layout fields must have children, cannot contain components" vertex="1">
          <mxGeometry height="22" width="410" x="10" y="53" as="geometry" />
        </mxCell>
        <mxCell id="val3" parent="ct_validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" value="component nesting depth max = 2 levels (component inside component)" vertex="1">
          <mxGeometry height="22" width="410" x="10" y="78" as="geometry" />
        </mxCell>
        <mxCell id="ct_example_title" parent="1" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#1565C0;fontStyle=1;" value="&lt;b&gt;Real Example: cv-page.json (collection)&lt;/b&gt;" vertex="1">
          <mxGeometry height="30" width="500" x="60" y="670" as="geometry" />
        </mxCell>
        <mxCell id="ct_example" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565C0;fontSize=10;align=left;verticalAlign=top;" value="&lt;pre style=&quot;text-align:left;font-size:10px;margin:0;padding:8px;&quot;&gt;{&lt;br&gt;  &quot;slug&quot;: &quot;cv-page&quot;, &quot;name&quot;: &quot;CV Page&quot;, &quot;kind&quot;: &quot;collection&quot;,&lt;br&gt;  &quot;fields&quot;: [&lt;br&gt;    { &quot;type&quot;: &quot;layout&quot;, &quot;fields&quot;: [            ← layout: groups position+isMain in one row&lt;br&gt;        { &quot;name&quot;: &quot;position&quot;, &quot;type&quot;: &quot;text&quot; },&lt;br&gt;        { &quot;name&quot;: &quot;isMain&quot;, &quot;type&quot;: &quot;boolean&quot; }&lt;br&gt;    ]},&lt;br&gt;    { &quot;name&quot;: &quot;company&quot;, &quot;type&quot;: &quot;text&quot; },&lt;br&gt;    { &quot;name&quot;: &quot;summary&quot;, &quot;type&quot;: &quot;richtext&quot; },&lt;br&gt;    {                                           ← component: creates separate table&lt;br&gt;      &quot;name&quot;: &quot;skills&quot;, &quot;type&quot;: &quot;component&quot;,&lt;br&gt;      &quot;repeatable&quot;: true,&lt;br&gt;      &quot;fields&quot;: [&lt;br&gt;        { &quot;name&quot;: &quot;level&quot;, &quot;type&quot;: &quot;text&quot; },&lt;br&gt;        { &quot;name&quot;: &quot;skill&quot;, &quot;type&quot;: &quot;text&quot; }&lt;br&gt;      ]&lt;br&gt;    },&lt;br&gt;    {&lt;br&gt;      &quot;name&quot;: &quot;experiences&quot;, &quot;type&quot;: &quot;component&quot;,  ← nested components (depth=1)&lt;br&gt;      &quot;repeatable&quot;: true,&lt;br&gt;      &quot;fields&quot;: [&lt;br&gt;        { &quot;type&quot;: &quot;layout&quot;, &quot;fields&quot;: [...] },&lt;br&gt;        {&lt;br&gt;          &quot;name&quot;: &quot;roles&quot;, &quot;type&quot;: &quot;component&quot;,  ← depth=2 (max allowed)&lt;br&gt;          &quot;repeatable&quot;: true,&lt;br&gt;          &quot;fields&quot;: [...]&lt;br&gt;        }&lt;br&gt;      ]&lt;br&gt;    }&lt;br&gt;  ]&lt;br&gt;}&lt;/pre&gt;" vertex="1">
          <mxGeometry height="415" width="580" x="60" y="720" as="geometry" />
        </mxCell>
        <mxCell id="ct_files_list" parent="1" style="swimlane;startSize=25;fillColor=#F3E5F5;strokeColor=#7B1FA2;rounded=1;fontSize=12;fontColor=#7B1FA2;" value="Current Content-Type Files" vertex="1">
          <mxGeometry height="170" width="380" x="690" y="730" as="geometry" />
        </mxCell>
        <mxCell id="cf1" parent="ct_files_list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="common-text.json — kind: &lt;b&gt;single&lt;/b&gt;, fields: [json]" vertex="1">
          <mxGeometry height="25" width="360" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="cf2" parent="ct_files_list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="cv-contact.json — kind: &lt;b&gt;single&lt;/b&gt;, fields: [layouts, media]" vertex="1">
          <mxGeometry height="25" width="360" x="10" y="60" as="geometry" />
        </mxCell>
        <mxCell id="cf3" parent="ct_files_list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="cv-page.json — kind: &lt;b&gt;collection&lt;/b&gt;, fields: [text, richtext, components]" vertex="1">
          <mxGeometry height="25" width="360" x="10" y="90" as="geometry" />
        </mxCell>
        <mxCell id="cf4" parent="ct_files_list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;spacingLeft=8;" value="en-vocab-pack.json — kind: &lt;b&gt;collection&lt;/b&gt;, fields: [text, components]" vertex="1">
          <mxGeometry height="25" width="360" x="10" y="120" as="geometry" />
        </mxCell>
        <mxCell id="ct_loading_note" parent="1" style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;align=left;spacingLeft=10;" value="&lt;b&gt;Loading Process&lt;/b&gt; (schema_loader.go)&lt;br&gt;&lt;font size=&quot;2&quot;&gt;1. LoadDefinitions(dir) reads all *.json files from CONTENT_TYPES_DIR&lt;br&gt;2. Parses each into ContentTypeDefinition struct&lt;br&gt;3. Validates: required fields, layout rules, component depth ≤ 2&lt;br&gt;4. Returns []ContentTypeDefinition for Syncer to process&lt;/font&gt;" vertex="1">
          <mxGeometry height="100" width="380" x="690" y="1010" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
